NODE_ENV={{ node_env }}
SERVICE_NAME={{ item.name }}
SWAGGER_SERVER_URL=http://{{ ip_api }}:{{ item.port }}
PORT={{ item.port }}
DB_HOST=127.0.0.1
DB_PORT={{ item.db_port }}
DB_NAME={{ item.db }}
DB_USER={{ pg_user }}
DB_PASSWORD={{ pg_password }}
JWT_SECRET={{ jwt_secret }}

{% if item.name == 'ms-auth-service' %}
JWT_ACCESS_EXPIRY={{ jwt_access_expiry }}
JWT_REFRESH_EXPIRY={{ jwt_refresh_expiry }}
{% endif %}

{% if item.name == 'ms-automotores' %}
AUTH_SERVICE_URL=http://{{ ip_api }}:8001
PERSONAS_SERVICE_URL=http://{{ ip_api }}:8002
{% endif %}

{% if item.name == 'ms-comparendos' %}
AUTH_SERVICE_URL=http://{{ ip_api }}:8001
PERSONAS_SERVICE_URL=http://{{ ip_api }}:8002
AUTOMOTORES_SERVICE_URL=http://{{ ip_api }}:8003
INFRACCIONES_SERVICE_URL=http://{{ ip_api }}:8004
{% endif %}

{% if item.name == 'ms-infracciones' %}
AUTH_SERVICE_URL=http://{{ ip_api }}:8001
{% endif %}

{% if item.name == 'ms-personas' %}
AUTH_SERVICE_URL=http://{{ ip_api }}:8001
{% endif %}
