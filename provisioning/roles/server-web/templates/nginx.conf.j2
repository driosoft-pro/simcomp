# ================================================================
# SIMCOMP — Nginx: API Gateway JWT + Frontend
# Generated by Ansible for {{ domain }}
# ================================================================

{% for svc in services %}
upstream {{ svc.name | replace('-', '_') }}_backend { 
    server {{ ip_api }}:{{ svc.port }}; 
    keepalive 16; 
}
{% endfor %}

# ── Gateways Individuales (3001-3005) ─────────────────────────────
{% for svc in services %}
server {
    listen {{ svc.gateway_port }};
    server_name {{ domain }} {{ ip_web }};

    location / {
        {% if svc.path != 'auth' %}
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauth_gw;
        {% endif %}

        proxy_pass         http://{{ svc.name | replace('-', '_') }}_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-Real-IP       $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        {% if svc.path != 'auth' %}
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
        {% endif %}
        proxy_read_timeout 60s;
    }

    location = /_auth_validate {
        internal;
        proxy_pass              http://ms_auth_service_backend/api/auth/validate;
        proxy_method            POST;
        proxy_pass_request_body off;
        proxy_set_header        Content-Length    "";
        proxy_set_header        Authorization     $http_authorization;
    }

    location @unauth_gw {
        default_type application/json;
        return 401 '{"error":"No autorizado","gateway_port":"{{ svc.gateway_port }}"}';
    }
}
{% endfor %}

# ── Servidor principal: {{ domain }} (Puerto 80) ───────────────────
server {
    listen 80;
    server_name {{ domain }} www.{{ domain }} {{ ip_web }};

    root  {{ frontend_dir }};
    index index.html;

    add_header X-Frame-Options        "SAMEORIGIN"    always;
    add_header X-Content-Type-Options "nosniff"       always;
    add_header X-XSS-Protection       "1; mode=block" always;

    location = /_auth_validate {
        internal;
        proxy_pass              http://ms_auth_service_backend/api/auth/validate;
        proxy_method            POST;
        proxy_pass_request_body off;
        proxy_set_header        Content-Length    "";
        proxy_set_header        Authorization     $http_authorization;
    }

    location /api/auth {
        proxy_pass         http://ms_auth_service_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-Real-IP       $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /api/usuarios {
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauthorized;

        proxy_pass         http://ms_auth_service_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
    }

    location /api/personas {
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauthorized;

        proxy_pass         http://ms_personas_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
    }

    location /api/licencias {
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauthorized;

        proxy_pass         http://ms_personas_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
    }

    location /api/automotores {
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauthorized;

        proxy_pass         http://ms_automotores_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
    }

    location /api/infracciones {
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauthorized;

        proxy_pass         http://ms_infracciones_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
    }

    location /api/comparendos {
        auth_request     /_auth_validate;
        auth_request_set $auth_user_id $upstream_http_x_user_id;
        auth_request_set $auth_role    $upstream_http_x_user_role;
        error_page 401 = @unauthorized;

        proxy_pass         http://ms_comparendos_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host            $host;
        proxy_set_header   X-User-ID       $auth_user_id;
        proxy_set_header   X-User-Role     $auth_role;
    }

    # ── Swagger Docs (sin auth) ────────────────────────────────
{% for svc in services %}
    location /docs/{{ svc.path }} { 
        proxy_pass http://{{ svc.name | replace('-', '_') }}_backend/api/docs; 
    }
{% endfor %}

    location @unauthorized {
        default_type application/json;
        return 401 '{"error":"No autorizado"}';
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    access_log /var/log/nginx/simcomp-access.log;
    error_log  /var/log/nginx/simcomp-error.log warn;
}

# ── api.{{ domain }} (acceso directo a la API) ───────────────────
server {
    listen 80;
    server_name api.{{ domain }};

    location = /_auth_validate {
        internal;
        proxy_pass              http://ms_auth_service_backend/api/auth/validate;
        proxy_method            POST;
        proxy_pass_request_body off;
        proxy_set_header        Content-Length "";
        proxy_set_header        Authorization  $http_authorization;
        proxy_read_timeout      5s;
    }

{% for svc in services %}
    location /api/{{ svc.name | replace('-service', '') }} {
        {% if svc.name != 'ms-auth-service' %}auth_request /_auth_validate; error_page 401 = @unauth_api;{% endif %}
        proxy_pass http://{{ svc.name | replace('-', '_') }}_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Headers "Content-Type, Authorization" always;
        if ($request_method = OPTIONS) { return 204; }
    }
{% endfor %}

    location @unauth_api { 
        default_type application/json; 
        return 401 '{"error":"No autorizado"}'; 
    }

    access_log /var/log/nginx/simcomp-api-access.log;
    error_log  /var/log/nginx/simcomp-api-error.log warn;
}
