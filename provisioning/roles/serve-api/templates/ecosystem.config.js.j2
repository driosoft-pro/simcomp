// ============================================================
// SIMCOMP — PM2 Ecosystem Config  (svr-api {{ ip_api }})
// Generated by Ansible
// ============================================================

module.exports = {
  apps: [
{% for svc in services %}
    {
      name:               '{{ svc.name }}',
      script:             '{{ app_base_dir }}/{{ svc.name }}/src/server.js',
      cwd:                '{{ app_base_dir }}/{{ svc.name }}',
      instances:          1,
      autorestart:        true,
      watch:              false,
      max_memory_restart: '300M',
      env: { 
        NODE_ENV: '{{ node_env }}', 
        PORT: {{ svc.port }} 
      },
      error_file:      '/var/log/simcomp/{{ svc.name }}-error.log',
      out_file:        '/var/log/simcomp/{{ svc.name }}-out.log',
      merge_logs:      true,
      log_date_format: 'YYYY-MM-DD HH:mm:ss'
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
};
